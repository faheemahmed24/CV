# Gemini API Configuration
# Get your key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Auth0 Configuration
# Get these from your Auth0 Dashboard (Applications -> Your App -> Settings)
# AUTH0_SECRET: A long, random string (at least 32 characters)
AUTH0_SECRET=
# AUTH0_BASE_URL: The base URL of your application (e.g., http://localhost:3000)
AUTH0_BASE_URL=
# AUTH0_ISSUER_BASE_URL: The domain of your Auth0 tenant (e.g., https://your-tenant.auth0.com)
AUTH0_ISSUER_BASE_URL=
# AUTH0_CLIENT_ID: The Client ID of your Auth0 application
AUTH0_CLIENT_ID=
# AUTH0_CLIENT_SECRET: The Client Secret of your Auth0 application
AUTH0_CLIENT_SECRET=

# Cloudflare D1 Database (Optional)
# Only required if you're using Cloudflare D1 for persistence
# DB=
